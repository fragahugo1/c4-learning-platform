    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "backbone": "^1.6.1",
    "jointjs": "^3.7.7",
    "jquery": "^4.0.0",
    "lodash": "^4.18.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.1",
